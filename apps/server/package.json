{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tsx --enable-source-maps src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "lint": "eslint .",
    "test": "npx tsx --test src/**/*.test.ts",
    "test:watch": "npx tsx --test --watch src/**/*.test.ts",
    "test:coverage": "npx tsx --test --experimental-test-coverage src/**/*.test.ts"
  },
  "dependencies": {
    "@valkey/valkey-glide": "^2.0.1",
    "express": "^4.21.2",
    "p-limit": "^6.1.0",
    "ramda": "^0.31.3",
    "valkey-common": "*",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "@types/ramda": "^0.31.1",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "~5.8.3",
    "vite": "^7.1.7"
  }
}
